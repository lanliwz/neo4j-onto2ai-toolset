<?xml version="1.0"?>
<rdf:RDF xmlns:onto2ai-am="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/"
     xml:base="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:fibo-fnd-pty-pty="https://spec.edmcouncil.org/fibo/ontology/FND/Parties/Parties/"
     xmlns:fibo-fbc-pas-caa="https://spec.edmcouncil.org/fibo/ontology/FBC/ProductsAndServices/ClientsAndAccounts/">
    <owl:Ontology rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement">
        <owl:imports rdf:resource="https://spec.edmcouncil.org/fibo/ontology/FND/Parties/Parties/"/>
        <owl:imports rdf:resource="https://spec.edmcouncil.org/fibo/ontology/FBC/ProductsAndServices/ClientsAndAccounts/"/>
    </owl:Ontology>

    <!-- Classes -->
    <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party">
        <rdfs:subClassOf rdf:resource="https://spec.edmcouncil.org/fibo/ontology/FND/Parties/Parties/Party"/>
        <rdfs:label>party</rdfs:label>
        <skos:definition>A legal entity or person acting as a party in a financial or legal context.</skos:definition>
    </owl:Class>

    <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Client">
        <rdfs:subClassOf rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:label>client</rdfs:label>
        <skos:definition>A person or entity using the services of a professional person or financial institution.</skos:definition>
    </owl:Class>

    <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account">
        <rdfs:subClassOf rdf:resource="https://spec.edmcouncil.org/fibo/ontology/FBC/ProductsAndServices/ClientsAndAccounts/CustomerAccount"/>
        <rdfs:label>account</rdfs:label>
        <skos:definition>A formal banking or financial account holding funds, securities, or tracking obligations.</skos:definition>
    </owl:Class>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/0XfrAgyFdAcctg -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/linksToTransferAgencyFundAccounting">
        <rdfs:label>fund accounting link</rdfs:label>
        <skos:definition xml:lang="en">A technical or operational banking relationship linking a transfer agency fund accounting.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/10DealClOnNonLglPrty -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isDealClientForNonLegalPartyOf">
        <rdfs:label>deal client for non-legal party</rdfs:label>
        <skos:definition xml:lang="en">Acting as deal client (Applied to an entity not recognized as an independent legal person).</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/120VaShdwAcct -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isVirtualShadowOf">
        <rdfs:label>shadow account</rdfs:label>
        <skos:definition xml:lang="en">A notional account used strictly for reporting, reconciliation, or mirroring a physical account's balances without holding actual funds.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/123CshRsvAccttoClntAcct -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isCashReserveFor">
        <rdfs:label>cash reserve to client account</rdfs:label>
        <skos:definition xml:lang="en">A technical or operational banking relationship linking a cash reserve account to client account.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/125Teta -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isTrusteeOf">
        <rdfs:label>trustee</rdfs:label>
        <skos:definition xml:lang="en">A person or firm that holds and administers property or assets for the benefit of a third party.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Client"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/1CollPrudOnNonLglPrty -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isCollateralProviderForNonLegalPartyOf">
        <rdfs:label>collateral provider for non-legal party</rdfs:label>
        <skos:definition xml:lang="en">Acting as collateral provider (Applied to an entity not recognized as an independent legal person).</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Client"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/1sPrmAstOwnrOnNonLglprty -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isPrimaryAssetOwnerForNonLegalPartyOf">
        <rdfs:label>primary asset owner for non-legal party</rdfs:label>
        <skos:definition xml:lang="en">Acting as primary asset owner (Applied to an entity not recognized as an independent legal person).</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/2Depositor -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isDepositorOf">
        <rdfs:label>depositor</rdfs:label>
        <skos:definition xml:lang="en">An individual or entity that places funds into a bank or financial institution account.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Client"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/6AuthSgnTy -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isAuthorizedSignatoryOf">
        <rdfs:label>authorized signatory</rdfs:label>
        <skos:definition xml:lang="en">An individual authorized to execute documents or conduct transactions on behalf of an entity or account.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Client"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/LOBClntOwny -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isLineOfBusinessOwnerOf">
        <rdfs:label>business line owner</rdfs:label>
        <skos:definition xml:lang="en">The specific line of business that owns the overall relationship with a client.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Client"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Acctnt -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isAccountantOf">
        <rdfs:label>accountant</rdfs:label>
        <skos:definition xml:lang="en">A professional responsible for keeping, interpreting, and auditing financial records.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Client"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Advs -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isAdvisorOf">
        <rdfs:label>advisor</rdfs:label>
        <skos:definition xml:lang="en">A professional providing financial, legal, or investment advice to clients.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/AdvsTa -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isTransferAgentAdvisorOf">
        <rdfs:label>transfer agent advisor</rdfs:label>
        <skos:definition xml:lang="en">An advisor acting in the capacity of a transfer agent.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/AgntOnNonLgiPrty -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isAgentForNonLegalPartyOf">
        <rdfs:label>agent for non-legal party</rdfs:label>
        <skos:definition xml:lang="en">Acting as agent (Applied to an entity not recognized as an independent legal person).</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Client"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Anlst -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isAnalystOf">
        <rdfs:label>analyst</rdfs:label>
        <skos:definition xml:lang="en">A financial professional who evaluates financial data and investment opportunities.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/AstOwnAddOnNonLgiPrty -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isAdditionalAssetOwnerForNonLegalPartyOf">
        <rdfs:label>additional asset owner for non-legal party</rdfs:label>
        <skos:definition xml:lang="en">Acting as asset own additional (Applied to an entity not recognized as an independent legal person).</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/AuthEnthlfCintPrsn -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isAuthorizedRepresentativeOf">
        <rdfs:label>authorized client representative</rdfs:label>
        <skos:definition xml:lang="en">An individual authorized to act on behalf of the client.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Client"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/AuthTpty -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isAuthorizedThirdPartyFor">
        <rdfs:label>authorized third party</rdfs:label>
        <skos:definition xml:lang="en">A non-primary party granted express permission to access information or perform specific actions regarding an account or relationship.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/BIScyPrudOnNonLglPrty -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isBeneficialInterestSecurityProviderForNonLegalPartyOf">
        <rdfs:label>beneficial interest security provider for non-legal party</rdfs:label>
        <skos:definition xml:lang="en">Acting as beneficial interest security provider (Applied to an entity not recognized as an independent legal person).</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Bene -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isBeneficiaryOf">
        <rdfs:label>beneficiary</rdfs:label>
        <skos:definition xml:lang="en">A person or entity entitled to receive the benefits, funds, or property from a trust, will, or financial product.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/BeneOnNonLglPrty -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isBeneficiaryForNonLegalPartyOf">
        <rdfs:label>beneficiary for non-legal party</rdfs:label>
        <skos:definition xml:lang="en">Acting as beneficiary (Applied to an entity not recognized as an independent legal person).</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/BeneOwnrOnNonglPrty -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isBeneficiaryOwnerForNonLegalPartyOf">
        <rdfs:label>beneficiary owner for non-legal party</rdfs:label>
        <skos:definition xml:lang="en">Acting as beneficiary owner (Applied to an entity not recognized as an independent legal person).</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/BkgLE -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isBookingLegalEntityFor">
        <rdfs:label>booking legal entity</rdfs:label>
        <skos:definition xml:lang="en">A party playing the role of bkg legal entity within a financial or legal contract.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Brkr -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isBrokerOf">
        <rdfs:label>broker</rdfs:label>
        <skos:definition xml:lang="en">An individual or firm that charges a fee or commission for executing buy and sell orders submitted by an investor.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/BrwrOnNonLglPrty -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isBorrowerForNonLegalPartyOf">
        <rdfs:label>borrower for non-legal party</rdfs:label>
        <skos:definition xml:lang="en">Acting as borrower (Applied to an entity not recognized as an independent legal person).</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Client"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Buyer -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isBuyerOf">
        <rdfs:label>buyer</rdfs:label>
        <skos:definition xml:lang="en">A party which acquires, or agrees to acquire, ownership, in exchange for money or other consideration.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Client"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/BuyerOnNonLgUPrty -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isBuyerForNonLegalPartyOf">
        <rdfs:label>buyer for non-legal party</rdfs:label>
        <skos:definition xml:lang="en">Acting as buyer (Applied to an entity not recognized as an independent legal person).</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Client"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/CFA -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isCharteredFinancialAnalystOf">
        <rdfs:label>CFA charterholder</rdfs:label>
        <skos:definition xml:lang="en">A professional holding the CFA designation, typically involved in investment analysis and portfolio management.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/CollRcVrBene -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isCollateralReceiverBeneficiaryOf">
        <rdfs:label>collateral receiver beneficiary</rdfs:label>
        <skos:definition xml:lang="en">A party playing the role of collateral receiver beneficiary within a financial or legal contract.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/COO -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isChiefOperatingOfficerOf">
        <rdfs:label>COO</rdfs:label>
        <skos:definition xml:lang="en">A senior executive primarily responsible for managing the day-to-day operations of a company.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/HasClient -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/hasClient">
        <rdfs:label>has client</rdfs:label>
        <skos:definition xml:lang="en">Relates an account to the client that uses or owns it.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Client"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/CntLE -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isCounterpartyLegalEntityFor">
        <rdfs:label>counterparty legal entity</rdfs:label>
        <skos:definition xml:lang="en">The counterparty legal entity involved in a financial transaction.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/CoLlMgrOnNonLgLPrty -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isCollateralManagerForNonLegalPartyOf">
        <rdfs:label>collateral manager for non-legal party</rdfs:label>
        <skos:definition xml:lang="en">Acting as collateral manager (Applied to an entity not recognized as an independent legal person).</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Client"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/CollPrud -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isCollateralProviderOf">
        <rdfs:label>collateral provider</rdfs:label>
        <skos:definition xml:lang="en">A party that pledges assets to secure a loan or other credit exposure.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Client"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/CollRevrAgnt -->
    <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/isCollateralReceiverAgentFor">
        <rdfs:label>collateral receiver agent</rdfs:label>
        <skos:definition xml:lang="en">An agent acting on behalf of the lender or secured party to hold or manage pledged collateral.</skos:definition>
        <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Party"/>
        <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Account"/>
    </owl:ObjectProperty>

    <!-- http://www.onto2ai-toolset.com/ontology/bank/AssetManagement/Cstdn -->
