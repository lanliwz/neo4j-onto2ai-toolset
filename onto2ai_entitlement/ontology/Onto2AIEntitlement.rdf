<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/"
    xml:base="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:skos="http://www.w3.org/2004/02/skos/core#"
    xmlns:onto2ai-ent="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/">

  <owl:Ontology rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/">
    <rdfs:label>onto2ai-entitlement</rdfs:label>
    <skos:definition xml:lang="en">Ontology for row-level and column-level entitlement enforcement across JDBC-accessible relational databases.</skos:definition>
    <owl:versionInfo>1.0.0</owl:versionInfo>
  </owl:Ontology>

  <!-- Classes -->
  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/User">
    <rdfs:label>user</rdfs:label>
    <skos:definition xml:lang="en">Principal that invokes or is evaluated against entitlement policies, including a human actor or an automated process.</skos:definition>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/userId"/>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/UserType">
    <rdfs:label>user type</rdfs:label>
    <skos:definition xml:lang="en">Classification of a user by the kind of actor it represents for entitlement evaluation.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/PolicyGroup">
    <rdfs:label>policy group</rdfs:label>
    <skos:definition xml:lang="en">Collection of policies mapped to a persona, role, or function.</skos:definition>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/policyGroupId"/>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/Policy">
    <rdfs:label>policy</rdfs:label>
    <skos:definition xml:lang="en">Bundle of row-filter and/or column-mask rules.</skos:definition>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/policyId"/>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RowFilterRule">
    <rdfs:label>row filter rule</rdfs:label>
    <skos:definition xml:lang="en">Rule that restricts row visibility using predicates.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/EntitlementRule"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/rowFilterRuleId"/>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ColumnMaskRule">
    <rdfs:label>column mask rule</rdfs:label>
    <skos:definition xml:lang="en">Rule that transforms or redacts sensitive column values.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/EntitlementRule"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/columnMaskRuleId"/>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RulePriority">
    <rdfs:label>rule priority</rdfs:label>
    <skos:definition xml:lang="en">Enumeration of precedence levels used to order entitlement rules during evaluation.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/FilterAction">
    <rdfs:label>filter action</rdfs:label>
    <skos:definition xml:lang="en">Enumeration of actions a row filter rule can apply during entitlement evaluation.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MatchMode">
    <rdfs:label>match mode</rdfs:label>
    <skos:definition xml:lang="en">Enumeration of value cardinality modes expected by a row filter rule.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ComparisonOperator">
    <rdfs:label>comparison operator</rdfs:label>
    <skos:definition xml:lang="en">Enumeration of comparison operators available to row filter predicates.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ValueSourceType">
    <rdfs:label>value source type</rdfs:label>
    <skos:definition xml:lang="en">Enumeration of runtime source categories used to resolve entitlement rule values.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/DenyBehavior">
    <rdfs:label>deny behavior</rdfs:label>
    <skos:definition xml:lang="en">Enumeration of enforcement behaviors applied when a row filter rule denies access.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MaskAction">
    <rdfs:label>mask action</rdfs:label>
    <skos:definition xml:lang="en">Enumeration of actions a column mask rule can apply to protected column values.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MaskingMethod">
    <rdfs:label>masking method</rdfs:label>
    <skos:definition xml:lang="en">Enumeration of masking or transformation strategies available to column mask rules.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/FallbackBehavior">
    <rdfs:label>fallback behavior</rdfs:label>
    <skos:definition xml:lang="en">Enumeration of fallback behaviors applied when a column mask rule cannot resolve masking inputs.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/SensitivityClassification">
    <rdfs:label>sensitivity classification</rdfs:label>
    <skos:definition xml:lang="en">Enumeration of data sensitivity levels used to classify relational columns for entitlement and masking decisions.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/EntitlementRule">
    <rdfs:label>entitlement rule</rdfs:label>
    <skos:definition xml:lang="en">Abstract superclass for entitlement rules that constrain row visibility or column values.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/Schema">
    <rdfs:label>schema</rdfs:label>
    <skos:definition xml:lang="en">Relational schema/container for tables.</skos:definition>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/schemaId"/>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/Table">
    <rdfs:label>table</rdfs:label>
    <skos:definition xml:lang="en">Relational table containing columns.</skos:definition>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/tableId"/>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/Column">
    <rdfs:label>column</rdfs:label>
    <skos:definition xml:lang="en">Relational column protected by entitlement rules.</skos:definition>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/columnId"/>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RelationalDatabase">
    <rdfs:label>relational database</rdfs:label>
    <skos:definition xml:lang="en">JDBC-connectable relational database platform.</skos:definition>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/relationalDatabaseId"/>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/JdbcConnectionProfile">
    <rdfs:label>jdbc connection profile</rdfs:label>
    <skos:definition xml:lang="en">JDBC endpoint and driver metadata for a target database.</skos:definition>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/jdbcConnectionProfileId"/>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <!-- Object properties -->
  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/isMemberOf">
    <rdfs:label>member of</rdfs:label>
    <skos:definition xml:lang="en">User inherits policies via policy group membership.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/User"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/PolicyGroup"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/hasUserType">
    <rdfs:label>has user type</rdfs:label>
    <skos:definition xml:lang="en">A user is classified by a user type that identifies whether it is a human actor or an automated process.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/User"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/UserType"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/includesPolicy">
    <rdfs:label>includes policy</rdfs:label>
    <skos:definition xml:lang="en">Policy group bundles one or more policies.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/PolicyGroup"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/Policy"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/hasRowFilterRule">
    <rdfs:label>has row filter rule</rdfs:label>
    <skos:definition xml:lang="en">Policy contains row-level filtering rules.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/Policy"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RowFilterRule"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/hasColumnMaskRule">
    <rdfs:label>has column mask rule</rdfs:label>
    <skos:definition xml:lang="en">Policy contains column masking rules.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/Policy"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ColumnMaskRule"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/targetsFilteredColumn">
    <rdfs:label>targets filtered column</rdfs:label>
    <skos:definition xml:lang="en">Row-filter rule targets a specific column context.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RowFilterRule"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/Column"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/targetsMaskedColumn">
    <rdfs:label>targets masked column</rdfs:label>
    <skos:definition xml:lang="en">Column-mask rule targets a specific column.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ColumnMaskRule"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/Column"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/hasSensitivityClassification">
    <rdfs:label>has sensitivity classification</rdfs:label>
    <skos:definition xml:lang="en">Associates a relational column with a data sensitivity classification used by entitlement and masking controls.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/Column"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/SensitivityClassification"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/hasPriority">
    <rdfs:label>has priority</rdfs:label>
    <skos:definition xml:lang="en">A row filter rule or column mask rule is assigned a priority level for evaluation order.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/EntitlementRule"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RulePriority"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/hasValueSourceType">
    <rdfs:label>has value source type</rdfs:label>
    <skos:definition xml:lang="en">Associates an entitlement rule with the runtime source category used to resolve rule values.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/EntitlementRule"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ValueSourceType"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/hasFilterAction">
    <rdfs:label>has filter action</rdfs:label>
    <skos:definition xml:lang="en">Associates a row filter rule with the action it applies when rewriting or evaluating a query.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RowFilterRule"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/FilterAction"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/hasMatchMode">
    <rdfs:label>has match mode</rdfs:label>
    <skos:definition xml:lang="en">Associates a row filter rule with the value cardinality mode it expects.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RowFilterRule"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MatchMode"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/hasComparisonOperator">
    <rdfs:label>has comparison operator</rdfs:label>
    <skos:definition xml:lang="en">Associates a row filter rule with the comparison operator used in its predicate.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RowFilterRule"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ComparisonOperator"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/hasDenyBehavior">
    <rdfs:label>has deny behavior</rdfs:label>
    <skos:definition xml:lang="en">Associates a row filter rule with the enforcement behavior used when access is denied.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RowFilterRule"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/DenyBehavior"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/hasMaskAction">
    <rdfs:label>has mask action</rdfs:label>
    <skos:definition xml:lang="en">Associates a column mask rule with the masking action it applies.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ColumnMaskRule"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MaskAction"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/hasMaskingMethod">
    <rdfs:label>has masking method</rdfs:label>
    <skos:definition xml:lang="en">Associates a column mask rule with the masking or transformation method it uses.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ColumnMaskRule"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MaskingMethod"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/hasFallbackBehavior">
    <rdfs:label>has fallback behavior</rdfs:label>
    <skos:definition xml:lang="en">Associates a column mask rule with the fallback behavior used when masking inputs cannot be resolved.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ColumnMaskRule"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/FallbackBehavior"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/belongsToTable">
    <rdfs:label>belongs to table</rdfs:label>
    <skos:definition xml:lang="en">A column belongs to exactly one table.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/Column"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/Table"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/belongsToSchema">
    <rdfs:label>belongs to schema</rdfs:label>
    <skos:definition xml:lang="en">A table belongs to exactly one schema.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/Table"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/Schema"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/belongsToDatabase">
    <rdfs:label>belongs to database</rdfs:label>
    <skos:definition xml:lang="en">Schema belongs to a relational database.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/Schema"/>
    <rdfs:range rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RelationalDatabase"/>
  </owl:ObjectProperty>

