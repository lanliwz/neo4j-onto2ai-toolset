  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/jdbcUrl">
    <rdfs:label>jdbc url</rdfs:label>
    <skos:definition xml:lang="en">The JDBC connection URL for a connection profile.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/JdbcConnectionProfile"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/jdbcDriver">
    <rdfs:label>jdbc driver</rdfs:label>
    <skos:definition xml:lang="en">The JDBC driver class or driver identifier for a connection profile.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/JdbcConnectionProfile"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/jdbcUserName">
    <rdfs:label>jdbc user name</rdfs:label>
    <skos:definition xml:lang="en">The user name used by a JDBC connection profile to authenticate to a database.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/JdbcConnectionProfile"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/connectionTimeoutSeconds">
    <rdfs:label>connection timeout seconds</rdfs:label>
    <skos:definition xml:lang="en">The connection timeout in seconds for a JDBC connection profile.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/JdbcConnectionProfile"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/sslMode">
    <rdfs:label>ssl mode</rdfs:label>
    <skos:definition xml:lang="en">The SSL or transport security mode configured for a JDBC connection profile.</skos:definition>
    <rdfs:domain rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/JdbcConnectionProfile"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <!-- Named individuals -->
  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/LowPriority">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RulePriority"/>
    <rdfs:label>low priority</rdfs:label>
    <skos:definition xml:lang="en">Priority level indicating a rule should be evaluated after higher-priority rules.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MediumPriority">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RulePriority"/>
    <rdfs:label>medium priority</rdfs:label>
    <skos:definition xml:lang="en">Priority level indicating a rule should be evaluated with standard precedence.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/HighPriority">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RulePriority"/>
    <rdfs:label>high priority</rdfs:label>
    <skos:definition xml:lang="en">Priority level indicating a rule should be evaluated before lower-priority rules.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/HumanUser">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/UserType"/>
    <rdfs:label>human user</rdfs:label>
    <skos:definition xml:lang="en">User type representing an individual human actor authenticated to access protected data.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ProcessUser">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/UserType"/>
    <rdfs:label>process user</rdfs:label>
    <skos:definition xml:lang="en">User type representing an automated process, service account, or system integration actor.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/AllowFilterAction">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/FilterAction"/>
    <rdfs:label>allow</rdfs:label>
    <skos:definition xml:lang="en">Filter action that permits access to rows matching the rule predicate.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/DenyFilterAction">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/FilterAction"/>
    <rdfs:label>deny</rdfs:label>
    <skos:definition xml:lang="en">Filter action that denies access to rows matching the rule predicate.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/NoValueMatchMode">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MatchMode"/>
    <rdfs:label>no value</rdfs:label>
    <skos:definition xml:lang="en">Match mode indicating the rule does not require a comparison value.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/SingleValueMatchMode">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MatchMode"/>
    <rdfs:label>single value</rdfs:label>
    <skos:definition xml:lang="en">Match mode indicating the rule expects one comparison value.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MultipleValuesMatchMode">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MatchMode"/>
    <rdfs:label>multiple values</rdfs:label>
    <skos:definition xml:lang="en">Match mode indicating the rule expects a collection of comparison values.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/EqualsComparisonOperator">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ComparisonOperator"/>
    <rdfs:label>equals</rdfs:label>
    <skos:definition xml:lang="en">Comparison operator for equality predicates.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/NotEqualsComparisonOperator">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ComparisonOperator"/>
    <rdfs:label>not equals</rdfs:label>
    <skos:definition xml:lang="en">Comparison operator for inequality predicates.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/InListComparisonOperator">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ComparisonOperator"/>
    <rdfs:label>in list</rdfs:label>
    <skos:definition xml:lang="en">Comparison operator requiring a value to appear in an allowed set.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/NotInListComparisonOperator">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ComparisonOperator"/>
    <rdfs:label>not in list</rdfs:label>
    <skos:definition xml:lang="en">Comparison operator requiring a value not to appear in a denied set.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/BetweenComparisonOperator">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ComparisonOperator"/>
    <rdfs:label>between</rdfs:label>
    <skos:definition xml:lang="en">Comparison operator requiring a value to fall between two bounds.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/StaticLiteralValueSourceType">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ValueSourceType"/>
    <rdfs:label>static literal</rdfs:label>
    <skos:definition xml:lang="en">Value source type where the rule stores a literal value directly.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/SubjectAttributeValueSourceType">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ValueSourceType"/>
    <rdfs:label>subject attribute</rdfs:label>
    <skos:definition xml:lang="en">Value source type resolved from an attribute of the evaluated user or principal.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/SessionContextValueSourceType">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ValueSourceType"/>
    <rdfs:label>session context</rdfs:label>
    <skos:definition xml:lang="en">Value source type resolved from the current authenticated session context.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RequestContextValueSourceType">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ValueSourceType"/>
    <rdfs:label>request context</rdfs:label>
    <skos:definition xml:lang="en">Value source type resolved from the current data access request context.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/DerivedQueryValueSourceType">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ValueSourceType"/>
    <rdfs:label>derived query</rdfs:label>
    <skos:definition xml:lang="en">Value source type resolved by executing or evaluating a derived lookup query.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ReturnNoRowsDenyBehavior">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/DenyBehavior"/>
    <rdfs:label>return no rows</rdfs:label>
    <skos:definition xml:lang="en">Deny behavior that rewrites access to produce an empty result set.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/BlockQueryDenyBehavior">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/DenyBehavior"/>
    <rdfs:label>block query</rdfs:label>
    <skos:definition xml:lang="en">Deny behavior that blocks the data access request.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RevealMaskAction">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MaskAction"/>
    <rdfs:label>reveal</rdfs:label>
    <skos:definition xml:lang="en">Mask action that reveals the original value.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RedactMaskAction">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MaskAction"/>
    <rdfs:label>redact</rdfs:label>
    <skos:definition xml:lang="en">Mask action that redacts the protected value.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/TokenizeMaskAction">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MaskAction"/>
    <rdfs:label>tokenize</rdfs:label>
    <skos:definition xml:lang="en">Mask action that replaces the original value with a token.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/SubstituteMaskAction">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MaskAction"/>
    <rdfs:label>substitute</rdfs:label>
    <skos:definition xml:lang="en">Mask action that substitutes the protected value with a configured replacement.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/NullifyMaskAction">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MaskAction"/>
    <rdfs:label>nullify</rdfs:label>
    <skos:definition xml:lang="en">Mask action that replaces the protected value with null.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/StaticSubstitutionMaskingMethod">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MaskingMethod"/>
    <rdfs:label>static substitution</rdfs:label>
    <skos:definition xml:lang="en">Masking method that emits a fixed replacement value.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/PatternMaskingMethod">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MaskingMethod"/>
    <rdfs:label>pattern masking</rdfs:label>
    <skos:definition xml:lang="en">Masking method that preserves a configured pattern while hiding protected portions of a value.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/HashingMaskingMethod">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MaskingMethod"/>
    <rdfs:label>hashing</rdfs:label>
    <skos:definition xml:lang="en">Masking method that emits a deterministic hash of the original value.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/TokenizationMaskingMethod">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MaskingMethod"/>
    <rdfs:label>tokenization</rdfs:label>
    <skos:definition xml:lang="en">Masking method that emits a reversible or managed token for the original value.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/NullReplacementMaskingMethod">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/MaskingMethod"/>
    <rdfs:label>null replacement</rdfs:label>
    <skos:definition xml:lang="en">Masking method that replaces the original value with null.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/BlockQueryFallbackBehavior">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/FallbackBehavior"/>
    <rdfs:label>block query</rdfs:label>
    <skos:definition xml:lang="en">Fallback behavior that blocks the query when masking inputs cannot be resolved.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ReturnNullFallbackBehavior">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/FallbackBehavior"/>
    <rdfs:label>return null</rdfs:label>
    <skos:definition xml:lang="en">Fallback behavior that returns null when masking inputs cannot be resolved.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/UseDefaultMaskFallbackBehavior">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/FallbackBehavior"/>
    <rdfs:label>use default mask</rdfs:label>
    <skos:definition xml:lang="en">Fallback behavior that applies a configured default mask when rule-specific inputs cannot be resolved.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/PublicSensitivityClassification">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/SensitivityClassification"/>
    <rdfs:label>public</rdfs:label>
    <skos:definition xml:lang="en">Sensitivity classification for data approved for public disclosure.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/InternalSensitivityClassification">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/SensitivityClassification"/>
    <rdfs:label>internal</rdfs:label>
    <skos:definition xml:lang="en">Sensitivity classification for data intended for internal organizational use.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/ConfidentialSensitivityClassification">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/SensitivityClassification"/>
    <rdfs:label>confidential</rdfs:label>
    <skos:definition xml:lang="en">Sensitivity classification for data requiring restricted access because disclosure could create business or privacy risk.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/RestrictedSensitivityClassification">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/SensitivityClassification"/>
    <rdfs:label>restricted</rdfs:label>
    <skos:definition xml:lang="en">Sensitivity classification for highly controlled data requiring strict access and masking governance.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/PIISensitivityClassification">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/SensitivityClassification"/>
    <rdfs:label>pii</rdfs:label>
    <skos:definition xml:lang="en">Sensitivity classification for personally identifiable information.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/PHISensitivityClassification">
    <rdf:type rdf:resource="http://www.onto2ai-toolset.com/ontology/entitlement/Onto2AIEntitlement/SensitivityClassification"/>
    <rdfs:label>phi</rdfs:label>
    <skos:definition xml:lang="en">Sensitivity classification for protected health information.</skos:definition>
  </owl:NamedIndividual>

</rdf:RDF>
