<?xml version="1.0"?>
<rdf:RDF
    xmlns="http://www.onto2ai-toolset.com/ontology/houseplan/HousePlan/#"
    xml:base="http://www.onto2ai-toolset.com/ontology/houseplan/HousePlan/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:skos="http://www.w3.org/2004/02/skos/core#">

  <owl:Ontology rdf:about="http://www.onto2ai-toolset.com/ontology/houseplan/HousePlan/">
    <rdfs:label>house plan ontology</rdfs:label>
    <skos:definition>Ontology for modeling residential house plans, levels, spaces, openings, fixtures, and plan annotations.</skos:definition>
  </owl:Ontology>

  <owl:Class rdf:about="#HousePlan">
    <rdfs:label>house plan</rdfs:label>
    <skos:definition>A structured plan describing the layout, spaces, openings, and annotations for a residential building.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#BuildingLevel">
    <rdfs:label>building level</rdfs:label>
    <skos:definition>A floor or split-level section within a house plan, such as a basement, main floor, or upper floor.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#Space">
    <rdfs:label>space</rdfs:label>
    <skos:definition>A bounded area within a building level that represents a functional portion of the floor plan.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#Room">
    <rdfs:subClassOf rdf:resource="#Space"/>
    <rdfs:label>room</rdfs:label>
    <skos:definition>A space intended for a specific residential use, such as sleeping, cooking, bathing, or working.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#Wall">
    <rdfs:label>wall</rdfs:label>
    <skos:definition>A vertical building element that bounds, partitions, or encloses one or more spaces in a house plan.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#Opening">
    <rdfs:label>opening</rdfs:label>
    <skos:definition>An opening formed in a wall to allow access, light, air, or visibility between spaces or to the exterior.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#Door">
    <rdfs:subClassOf rdf:resource="#Opening"/>
    <rdfs:label>door</rdfs:label>
    <skos:definition>An operable opening primarily used to permit passage between spaces or between the building interior and exterior.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#Window">
    <rdfs:subClassOf rdf:resource="#Opening"/>
    <rdfs:label>window</rdfs:label>
    <skos:definition>An opening designed to admit daylight, ventilation, or views while remaining part of the building envelope.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#Fixture">
    <rdfs:label>fixture</rdfs:label>
    <skos:definition>A built-in or planned element located within a space, such as cabinetry, plumbing fixtures, or appliances.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#DimensionAnnotation">
    <rdfs:label>dimension annotation</rdfs:label>
    <skos:definition>An annotation that records measured distances, sizes, or dimensional notes on a house plan.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#MaterialSpecification">
    <rdfs:label>material specification</rdfs:label>
    <skos:definition>A specification describing an intended construction material or finish associated with a house plan element.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#Address">
    <rdfs:label>address</rdfs:label>
    <skos:definition>A structured location designator used to describe the civic location of a house plan site.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#USPostalAddress">
    <rdfs:subClassOf rdf:resource="#Address"/>
    <rdfs:label>US postal address</rdfs:label>
    <skos:definition>A United States civic mailing or site address including street, municipality, state, and postal code components.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#GPSCoordinate">
    <rdfs:label>GPS coordinate</rdfs:label>
    <skos:definition>A geospatial coordinate describing the latitude and longitude of a house plan site or surveyed point.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#SurveyReference">
    <rdfs:label>survey reference</rdfs:label>
    <skos:definition>A survey record or legal reference describing parcel boundaries, lot designations, and site measurement context for a house plan.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#Parcel">
    <rdfs:label>parcel</rdfs:label>
    <skos:definition>A legally identified tract of land associated with a house plan site and referenced by address, survey, or tax records.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#GeoJSONFeatureCollection">
    <rdfs:label>GeoJSON feature collection</rdfs:label>
    <skos:definition>A GeoJSON feature collection resource that groups one or more features from a source file.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#GeoJSONFeature">
    <rdfs:label>GeoJSON feature</rdfs:label>
    <skos:definition>A GeoJSON feature that carries source properties and a geometry describing a mapped parcel or other site object.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#Geometry">
    <rdfs:label>geometry</rdfs:label>
    <skos:definition>A geometric representation of a mapped object, such as a point, line, or polygon.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#PolygonGeometry">
    <rdfs:subClassOf rdf:resource="#Geometry"/>
    <rdfs:label>polygon geometry</rdfs:label>
    <skos:definition>A closed polygon geometry used to represent an areal boundary, such as a tax parcel footprint.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#BoundaryVertex">
    <rdfs:subClassOf rdf:resource="#GPSCoordinate"/>
    <rdfs:label>boundary vertex</rdfs:label>
    <skos:definition>A GPS coordinate used as an ordered vertex in a polygon boundary.</skos:definition>
  </owl:Class>

  <owl:Class rdf:about="#RoomClassification">
    <rdfs:label>room classification</rdfs:label>
    <skos:definition>An enumeration of common residential room types used to classify rooms in a house plan.</skos:definition>
  </owl:Class>

  <owl:ObjectProperty rdf:about="#hasLevel">
    <rdfs:label>has level</rdfs:label>
    <skos:definition>Relates a house plan to a building level that is part of the plan.</skos:definition>
    <rdfs:domain rdf:resource="#HousePlan"/>
    <rdfs:range rdf:resource="#BuildingLevel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#containsSpace">
    <rdfs:label>contains space</rdfs:label>
    <skos:definition>Relates a building level to a space located on that level.</skos:definition>
    <rdfs:domain rdf:resource="#BuildingLevel"/>
    <rdfs:range rdf:resource="#Space"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#isAdjacentTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:label>is adjacent to</rdfs:label>
    <skos:definition>Relates one space to another space that shares a boundary or direct connection.</skos:definition>
    <rdfs:domain rdf:resource="#Space"/>
    <rdfs:range rdf:resource="#Space"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#isBoundedBy">
    <rdfs:label>is bounded by</rdfs:label>
    <skos:definition>Relates a space to a wall that forms part of its perimeter.</skos:definition>
    <rdfs:domain rdf:resource="#Space"/>
    <rdfs:range rdf:resource="#Wall"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hostsOpening">
    <rdfs:label>hosts opening</rdfs:label>
    <skos:definition>Relates a wall to an opening formed within that wall.</skos:definition>
    <rdfs:domain rdf:resource="#Wall"/>
    <rdfs:range rdf:resource="#Opening"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#connectsFromSpace">
    <rdfs:label>connects from space</rdfs:label>
    <skos:definition>Relates an opening to the originating space connected by that opening.</skos:definition>
    <rdfs:domain rdf:resource="#Opening"/>
    <rdfs:range rdf:resource="#Space"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#connectsToSpace">
    <rdfs:label>connects to space</rdfs:label>
    <skos:definition>Relates an opening to the destination space connected by that opening.</skos:definition>
    <rdfs:domain rdf:resource="#Opening"/>
    <rdfs:range rdf:resource="#Space"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#containsFixture">
    <rdfs:label>contains fixture</rdfs:label>
    <skos:definition>Relates a space to a fixture planned or installed within that space.</skos:definition>
    <rdfs:domain rdf:resource="#Space"/>
    <rdfs:range rdf:resource="#Fixture"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasDimensionAnnotation">
    <rdfs:label>has dimension annotation</rdfs:label>
    <skos:definition>Relates a house plan to a dimension annotation recorded on the plan.</skos:definition>
    <rdfs:domain rdf:resource="#HousePlan"/>
    <rdfs:range rdf:resource="#DimensionAnnotation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#usesMaterialSpecification">
    <rdfs:label>uses material specification</rdfs:label>
    <skos:definition>Relates a house plan element to a material specification that describes its intended construction or finish.</skos:definition>
    <rdfs:domain rdf:resource="#HousePlan"/>
    <rdfs:range rdf:resource="#MaterialSpecification"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasSiteAddress">
    <rdfs:label>has site address</rdfs:label>
    <skos:definition>Relates a house plan to the United States postal address of the planned site.</skos:definition>
    <rdfs:domain rdf:resource="#HousePlan"/>
    <rdfs:range rdf:resource="#USPostalAddress"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasGPSCoordinate">
    <rdfs:label>has GPS coordinate</rdfs:label>
    <skos:definition>Relates a house plan to a GPS coordinate representing the site location.</skos:definition>
    <rdfs:domain rdf:resource="#HousePlan"/>
    <rdfs:range rdf:resource="#GPSCoordinate"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasSurveyReference">
    <rdfs:label>has survey reference</rdfs:label>
    <skos:definition>Relates a house plan to a survey reference that captures parcel, lot, and legal survey context.</skos:definition>
    <rdfs:domain rdf:resource="#HousePlan"/>
    <rdfs:range rdf:resource="#SurveyReference"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasParcel">
    <rdfs:label>has parcel</rdfs:label>
    <skos:definition>Relates a house plan to the parcel of land on which the planned house is situated.</skos:definition>
    <rdfs:domain rdf:resource="#HousePlan"/>
    <rdfs:range rdf:resource="#Parcel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasParcelAddress">
    <rdfs:label>has parcel address</rdfs:label>
    <skos:definition>Relates a parcel to the United States postal address associated with that parcel record.</skos:definition>
    <rdfs:domain rdf:resource="#Parcel"/>
    <rdfs:range rdf:resource="#USPostalAddress"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#describesParcel">
    <rdfs:label>describes parcel</rdfs:label>
    <skos:definition>Relates a survey reference to the parcel whose boundaries or legal description it documents.</skos:definition>
    <rdfs:domain rdf:resource="#SurveyReference"/>
    <rdfs:range rdf:resource="#Parcel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasSourceFeatureCollection">
    <rdfs:label>has source feature collection</rdfs:label>
    <skos:definition>Relates a house plan or parcel dataset to the GeoJSON feature collection from which parcel records were obtained.</skos:definition>
    <rdfs:domain rdf:resource="#HousePlan"/>
    <rdfs:range rdf:resource="#GeoJSONFeatureCollection"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasFeature">
    <rdfs:label>has feature</rdfs:label>
    <skos:definition>Relates a GeoJSON feature collection to a contained GeoJSON feature.</skos:definition>
    <rdfs:domain rdf:resource="#GeoJSONFeatureCollection"/>
    <rdfs:range rdf:resource="#GeoJSONFeature"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#representsParcel">
    <rdfs:label>represents parcel</rdfs:label>
    <skos:definition>Relates a GeoJSON feature to the parcel represented by that feature.</skos:definition>
    <rdfs:domain rdf:resource="#GeoJSONFeature"/>
    <rdfs:range rdf:resource="#Parcel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasGeometry">
    <rdfs:label>has geometry</rdfs:label>
    <skos:definition>Relates a GeoJSON feature or parcel to its geometry representation.</skos:definition>
    <rdfs:domain rdf:resource="#GeoJSONFeature"/>
    <rdfs:range rdf:resource="#Geometry"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasParcelGeometry">
    <rdfs:label>has parcel geometry</rdfs:label>
    <skos:definition>Relates a parcel to the polygon geometry that describes its mapped boundary.</skos:definition>
    <rdfs:domain rdf:resource="#Parcel"/>
    <rdfs:range rdf:resource="#PolygonGeometry"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasBoundaryVertex">
    <rdfs:label>has boundary vertex</rdfs:label>
    <skos:definition>Relates a polygon geometry to an ordered boundary vertex used to trace the polygon ring.</skos:definition>
    <rdfs:domain rdf:resource="#PolygonGeometry"/>
    <rdfs:range rdf:resource="#BoundaryVertex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasRoomClassification">
    <rdfs:label>has room classification</rdfs:label>
    <skos:definition>Relates a room to a room classification individual representing its intended use.</skos:definition>
    <rdfs:domain rdf:resource="#Room"/>
    <rdfs:range rdf:resource="#RoomClassification"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="#housePlanId">
    <rdfs:label>house plan id</rdfs:label>
    <skos:definition>Stable identifier for a house plan.</skos:definition>
    <rdfs:domain rdf:resource="#HousePlan"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#planName">
    <rdfs:label>plan name</rdfs:label>
    <skos:definition>Human-readable name of a house plan.</skos:definition>
    <rdfs:domain rdf:resource="#HousePlan"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#scaleText">
    <rdfs:label>scale text</rdfs:label>
    <skos:definition>Printed or declared drawing scale associated with a house plan.</skos:definition>
    <rdfs:domain rdf:resource="#HousePlan"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#grossAreaSquareFeet">
    <rdfs:label>gross area square feet</rdfs:label>
    <skos:definition>Total gross floor area represented by a house plan in square feet.</skos:definition>
    <rdfs:domain rdf:resource="#HousePlan"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#levelId">
    <rdfs:label>level id</rdfs:label>
    <skos:definition>Stable identifier for a building level.</skos:definition>
    <rdfs:domain rdf:resource="#BuildingLevel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#levelName">
    <rdfs:label>level name</rdfs:label>
    <skos:definition>Human-readable name of a building level.</skos:definition>
    <rdfs:domain rdf:resource="#BuildingLevel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#elevationFeet">
    <rdfs:label>elevation feet</rdfs:label>
    <skos:definition>Elevation of a building level relative to the reference datum in feet.</skos:definition>
    <rdfs:domain rdf:resource="#BuildingLevel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#spaceId">
    <rdfs:label>space id</rdfs:label>
    <skos:definition>Stable identifier for a space.</skos:definition>
    <rdfs:domain rdf:resource="#Space"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#spaceName">
    <rdfs:label>space name</rdfs:label>
    <skos:definition>Human-readable name assigned to a space.</skos:definition>
    <rdfs:domain rdf:resource="#Space"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#netAreaSquareFeet">
    <rdfs:label>net area square feet</rdfs:label>
    <skos:definition>Usable area of a space measured in square feet.</skos:definition>
    <rdfs:domain rdf:resource="#Space"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#ceilingHeightFeet">
    <rdfs:label>ceiling height feet</rdfs:label>
    <skos:definition>Nominal interior ceiling height of a space in feet.</skos:definition>
    <rdfs:domain rdf:resource="#Space"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#wallId">
    <rdfs:label>wall id</rdfs:label>
    <skos:definition>Stable identifier for a wall.</skos:definition>
    <rdfs:domain rdf:resource="#Wall"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#wallLengthFeet">
    <rdfs:label>wall length feet</rdfs:label>
    <skos:definition>Length of a wall segment in feet.</skos:definition>
    <rdfs:domain rdf:resource="#Wall"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#wallThicknessInches">
    <rdfs:label>wall thickness inches</rdfs:label>
    <skos:definition>Thickness of a wall measured in inches.</skos:definition>
    <rdfs:domain rdf:resource="#Wall"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#openingId">
    <rdfs:label>opening id</rdfs:label>
    <skos:definition>Stable identifier for an opening.</skos:definition>
    <rdfs:domain rdf:resource="#Opening"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#openingWidthFeet">
    <rdfs:label>opening width feet</rdfs:label>
    <skos:definition>Nominal clear width of an opening in feet.</skos:definition>
    <rdfs:domain rdf:resource="#Opening"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#openingHeightFeet">
    <rdfs:label>opening height feet</rdfs:label>
    <skos:definition>Nominal clear height of an opening in feet.</skos:definition>
    <rdfs:domain rdf:resource="#Opening"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#fixtureId">
    <rdfs:label>fixture id</rdfs:label>
    <skos:definition>Stable identifier for a fixture.</skos:definition>
    <rdfs:domain rdf:resource="#Fixture"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#fixtureName">
    <rdfs:label>fixture name</rdfs:label>
    <skos:definition>Human-readable name of a fixture.</skos:definition>
    <rdfs:domain rdf:resource="#Fixture"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#dimensionAnnotationId">
    <rdfs:label>dimension annotation id</rdfs:label>
    <skos:definition>Stable identifier for a dimension annotation.</skos:definition>
    <rdfs:domain rdf:resource="#DimensionAnnotation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#dimensionText">
    <rdfs:label>dimension text</rdfs:label>
    <skos:definition>Displayed text value of a dimension annotation.</skos:definition>
    <rdfs:domain rdf:resource="#DimensionAnnotation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#materialSpecificationId">
    <rdfs:label>material specification id</rdfs:label>
    <skos:definition>Stable identifier for a material specification.</skos:definition>
    <rdfs:domain rdf:resource="#MaterialSpecification"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#materialName">
    <rdfs:label>material name</rdfs:label>
    <skos:definition>Human-readable name of a material or finish.</skos:definition>
    <rdfs:domain rdf:resource="#MaterialSpecification"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#addressId">
    <rdfs:label>address id</rdfs:label>
    <skos:definition>Stable identifier for an address.</skos:definition>
    <rdfs:domain rdf:resource="#Address"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#streetAddressLine1">
    <rdfs:label>street address line 1</rdfs:label>
    <skos:definition>Primary delivery or site address line for a United States postal address.</skos:definition>
    <rdfs:domain rdf:resource="#USPostalAddress"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#streetAddressLine2">
    <rdfs:label>street address line 2</rdfs:label>
    <skos:definition>Secondary address line such as apartment, suite, or unit designator.</skos:definition>
    <rdfs:domain rdf:resource="#USPostalAddress"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#cityName">
    <rdfs:label>city name</rdfs:label>
    <skos:definition>Municipality or city component of a United States postal address.</skos:definition>
    <rdfs:domain rdf:resource="#USPostalAddress"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#stateCode">
    <rdfs:label>state code</rdfs:label>
    <skos:definition>Two-letter United States state or territory abbreviation for a postal address.</skos:definition>
    <rdfs:domain rdf:resource="#USPostalAddress"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#postalCode">
    <rdfs:label>postal code</rdfs:label>
    <skos:definition>United States ZIP code associated with a postal address.</skos:definition>
    <rdfs:domain rdf:resource="#USPostalAddress"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#countyName">
    <rdfs:label>county name</rdfs:label>
    <skos:definition>County or county-equivalent jurisdiction for a United States postal address.</skos:definition>
    <rdfs:domain rdf:resource="#USPostalAddress"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#gpsCoordinateId">
    <rdfs:label>GPS coordinate id</rdfs:label>
    <skos:definition>Stable identifier for a GPS coordinate record.</skos:definition>
    <rdfs:domain rdf:resource="#GPSCoordinate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#latitudeDecimalDegrees">
    <rdfs:label>latitude decimal degrees</rdfs:label>
    <skos:definition>Latitude of a GPS coordinate expressed in decimal degrees.</skos:definition>
    <rdfs:domain rdf:resource="#GPSCoordinate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#longitudeDecimalDegrees">
    <rdfs:label>longitude decimal degrees</rdfs:label>
    <skos:definition>Longitude of a GPS coordinate expressed in decimal degrees.</skos:definition>
    <rdfs:domain rdf:resource="#GPSCoordinate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#horizontalDatumName">
    <rdfs:label>horizontal datum name</rdfs:label>
    <skos:definition>Named geodetic datum used for the GPS coordinate, such as WGS84.</skos:definition>
    <rdfs:domain rdf:resource="#GPSCoordinate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#elevationAboveSeaLevelFeet">
    <rdfs:label>elevation above sea level feet</rdfs:label>
    <skos:definition>Elevation of the GPS coordinate above mean sea level in feet.</skos:definition>
    <rdfs:domain rdf:resource="#GPSCoordinate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#surveyReferenceId">
    <rdfs:label>survey reference id</rdfs:label>
    <skos:definition>Stable identifier for a survey reference.</skos:definition>
    <rdfs:domain rdf:resource="#SurveyReference"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#parcelId">
    <rdfs:label>parcel id</rdfs:label>
    <skos:definition>Stable identifier for a parcel.</skos:definition>
    <rdfs:domain rdf:resource="#Parcel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#parcelNumber">
    <rdfs:label>parcel number</rdfs:label>
    <skos:definition>Assessor, cadastral, or parcel number assigned to the tract of land.</skos:definition>
    <rdfs:domain rdf:resource="#Parcel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#taxMapNumber">
    <rdfs:label>tax map number</rdfs:label>
    <skos:definition>Tax map, block-lot, or similar local jurisdiction reference used to identify the parcel.</skos:definition>
    <rdfs:domain rdf:resource="#Parcel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#parcelAreaSquareFeet">
    <rdfs:label>parcel area square feet</rdfs:label>
    <skos:definition>Area of the parcel expressed in square feet.</skos:definition>
    <rdfs:domain rdf:resource="#Parcel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#zoningCode">
    <rdfs:label>zoning code</rdfs:label>
    <skos:definition>Zoning district or land-use code applicable to the parcel.</skos:definition>
    <rdfs:domain rdf:resource="#Parcel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#parcelAreaAcres">
    <rdfs:label>parcel area acres</rdfs:label>
    <skos:definition>Area of the parcel expressed in acres, matching acreage-oriented parcel source files.</skos:definition>
    <rdfs:domain rdf:resource="#Parcel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#deededAreaAcres">
    <rdfs:label>deeded area acres</rdfs:label>
    <skos:definition>Recorded deed area of the parcel expressed in acres.</skos:definition>
    <rdfs:domain rdf:resource="#Parcel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#taxDistrictCode">
    <rdfs:label>tax district code</rdfs:label>
    <skos:definition>District code assigned to the parcel in the source tax parcel dataset.</skos:definition>
    <rdfs:domain rdf:resource="#Parcel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#taxSectionCode">
    <rdfs:label>tax section code</rdfs:label>
    <skos:definition>Section code assigned to the parcel in the source tax parcel dataset.</skos:definition>
    <rdfs:domain rdf:resource="#Parcel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#municipalityName">
    <rdfs:label>municipality name</rdfs:label>
    <skos:definition>Municipality or locality name associated with the parcel in the source dataset.</skos:definition>
    <rdfs:domain rdf:resource="#Parcel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#landUseText">
    <rdfs:label>land use text</rdfs:label>
    <skos:definition>Land-use code and description string assigned to the parcel in the source dataset.</skos:definition>
    <rdfs:domain rdf:resource="#Parcel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#parcelStatusText">
    <rdfs:label>parcel status text</rdfs:label>
    <skos:definition>Status string assigned to the parcel in the source dataset, such as ACTIVE.</skos:definition>
    <rdfs:domain rdf:resource="#Parcel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#titleFlagText">
    <rdfs:label>title flag text</rdfs:label>
    <skos:definition>Source flag indicating whether the parcel record is title-related in the input dataset.</skos:definition>
    <rdfs:domain rdf:resource="#Parcel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#overlapFlagText">
    <rdfs:label>overlap flag text</rdfs:label>
    <skos:definition>Source flag indicating whether the parcel overlaps another mapped area in the input dataset.</skos:definition>
    <rdfs:domain rdf:resource="#Parcel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#sourceObjectId">
    <rdfs:label>source object id</rdfs:label>
    <skos:definition>Object identifier assigned to a parcel feature by the source GeoJSON dataset.</skos:definition>
    <rdfs:domain rdf:resource="#GeoJSONFeature"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#featureCollectionId">
    <rdfs:label>feature collection id</rdfs:label>
    <skos:definition>Stable identifier for a GeoJSON feature collection resource.</skos:definition>
    <rdfs:domain rdf:resource="#GeoJSONFeatureCollection"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#featureId">
    <rdfs:label>feature id</rdfs:label>
    <skos:definition>Stable identifier for a GeoJSON feature resource.</skos:definition>
    <rdfs:domain rdf:resource="#GeoJSONFeature"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#geometryId">
    <rdfs:label>geometry id</rdfs:label>
    <skos:definition>Stable identifier for a geometry resource.</skos:definition>
    <rdfs:domain rdf:resource="#Geometry"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#geometryTypeName">
    <rdfs:label>geometry type name</rdfs:label>
    <skos:definition>Geometry type name captured from the source dataset, such as Polygon.</skos:definition>
    <rdfs:domain rdf:resource="#Geometry"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#ringCount">
    <rdfs:label>ring count</rdfs:label>
    <skos:definition>Number of polygon rings encoded in a polygon geometry.</skos:definition>
    <rdfs:domain rdf:resource="#PolygonGeometry"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#vertexOrder">
    <rdfs:label>vertex order</rdfs:label>
    <skos:definition>Zero-based or one-based sequence index used to preserve vertex order within a polygon ring.</skos:definition>
    <rdfs:domain rdf:resource="#BoundaryVertex"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#sourceCreatedAtText">
    <rdfs:label>source created at text</rdfs:label>
    <skos:definition>Creation timestamp text captured verbatim from the source GeoJSON dataset.</skos:definition>
    <rdfs:domain rdf:resource="#GeoJSONFeature"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#sourceLastUpdatedAtText">
    <rdfs:label>source last updated at text</rdfs:label>
    <skos:definition>Last-update timestamp text captured verbatim from the source GeoJSON dataset.</skos:definition>
    <rdfs:domain rdf:resource="#GeoJSONFeature"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#fullAddressText">
    <rdfs:label>full address text</rdfs:label>
    <skos:definition>Full address string captured from a source dataset for a site or parcel.</skos:definition>
    <rdfs:domain rdf:resource="#Address"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#parcelIdentifier">
    <rdfs:label>parcel identifier</rdfs:label>
    <skos:definition>Parcel or tax map identifier associated with the surveyed site.</skos:definition>
    <rdfs:domain rdf:resource="#SurveyReference"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#lotNumber">
    <rdfs:label>lot number</rdfs:label>
    <skos:definition>Lot designation referenced by the survey or subdivision record.</skos:definition>
    <rdfs:domain rdf:resource="#SurveyReference"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#blockNumber">
    <rdfs:label>block number</rdfs:label>
    <skos:definition>Block designation referenced by the survey or subdivision record.</skos:definition>
    <rdfs:domain rdf:resource="#SurveyReference"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#subdivisionName">
    <rdfs:label>subdivision name</rdfs:label>
    <skos:definition>Name of the subdivision, tract, or filed map associated with the surveyed site.</skos:definition>
    <rdfs:domain rdf:resource="#SurveyReference"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#surveyBookReference">
    <rdfs:label>survey book reference</rdfs:label>
    <skos:definition>Survey book or map book reference used to locate the official survey record.</skos:definition>
    <rdfs:domain rdf:resource="#SurveyReference"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#surveyPageReference">
    <rdfs:label>survey page reference</rdfs:label>
    <skos:definition>Survey page or sheet reference used to locate the official survey record.</skos:definition>
    <rdfs:domain rdf:resource="#SurveyReference"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#legalDescriptionText">
    <rdfs:label>legal description text</rdfs:label>
    <skos:definition>Textual legal description of the parcel or surveyed site boundaries.</skos:definition>
    <rdfs:domain rdf:resource="#SurveyReference"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:NamedIndividual rdf:about="#Bedroom">
    <rdf:type rdf:resource="#RoomClassification"/>
    <rdfs:label>bedroom</rdfs:label>
    <skos:definition>Room classification for a sleeping space.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Bathroom">
    <rdf:type rdf:resource="#RoomClassification"/>
    <rdfs:label>bathroom</rdfs:label>
    <skos:definition>Room classification for a space used for bathing and personal hygiene.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Kitchen">
    <rdf:type rdf:resource="#RoomClassification"/>
    <rdfs:label>kitchen</rdfs:label>
    <skos:definition>Room classification for a space used for food preparation and cooking.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#LivingRoom">
    <rdf:type rdf:resource="#RoomClassification"/>
    <rdfs:label>living room</rdfs:label>
    <skos:definition>Room classification for a shared living and gathering area.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#DiningRoom">
    <rdf:type rdf:resource="#RoomClassification"/>
    <rdfs:label>dining room</rdfs:label>
    <skos:definition>Room classification for a space primarily intended for dining.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Office">
    <rdf:type rdf:resource="#RoomClassification"/>
    <rdfs:label>office</rdfs:label>
    <skos:definition>Room classification for a workspace or study.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#LaundryRoom">
    <rdf:type rdf:resource="#RoomClassification"/>
    <rdfs:label>laundry room</rdfs:label>
    <skos:definition>Room classification for a space dedicated to laundry equipment and tasks.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Garage">
    <rdf:type rdf:resource="#RoomClassification"/>
    <rdfs:label>garage</rdfs:label>
    <skos:definition>Room classification for an enclosed vehicle storage space.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Hallway">
    <rdf:type rdf:resource="#RoomClassification"/>
    <rdfs:label>hallway</rdfs:label>
    <skos:definition>Room classification for a circulation space connecting rooms.</skos:definition>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Storage">
    <rdf:type rdf:resource="#RoomClassification"/>
    <rdfs:label>storage</rdfs:label>
